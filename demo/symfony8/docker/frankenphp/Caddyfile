{
	skip_install_trust
	# Timeout hierarchy (REQ-RUNTIME-001):
	#   process() timeout (PROCESS_TIMEOUT)  <  PHP max_execution_time  <  Caddy write timeout
	# max_wait_time bounds the queue when workers are busy merging templates (avoids endless backlog).
	servers {
		timeouts {
			read_body 60s
			read_header 30s
			write 250s
			idle 5m
		}
	}
	frankenphp {
		php_ini max_execution_time 240
		php_ini max_input_time 240
		max_wait_time 30s
	}
}

:80 {
	root * /app/public
	encode zstd br gzip
	php_server {
		worker /app/public/index.php 2
	}
}

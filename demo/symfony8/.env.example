# Demo environment template. Copy to .env (e.g. cp .env.example .env) and adjust.
# Do not commit .env, .env.dev, or other local .env* files — use this file as reference.

# HTTP port exposed by docker-compose for this demo.
PORT=8021

###> symfony/framework-bundle ###
# APP_ENV: Symfony environment used by the demo container (docker-compose also forces dev).
APP_ENV=dev
APP_DEBUG=1

# FRANKENPHP_MODE: FrankenPHP runtime mode — `classic` (one process per request) or `worker` (long-lived workers).
# Default: worker. Set classic for per-request PHP / easier hot-reload. Recreate with `docker compose up -d` after change.
FRANKENPHP_MODE=worker
APP_SECRET=change_this_secret_key_to_a_random_value
###< symfony/framework-bundle ###

# PROCESS_TIMEOUT: Shared Nowo wall-clock timeout (seconds) for WordTemplateProcessor::process()
# (nowo_word_template.timeout — cooperative deadline + set_time_limit). Default 180.
# Keep PHP max_execution_time (240) and Caddy write (250s) above this value.
# See docs/DEMO-FRANKENPHP.md (REQ-RUNTIME-001).
PROCESS_TIMEOUT=180

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost:8021
###< symfony/routing ###

###> symfony/var-dumper ###
VAR_DUMPER_SERVER=127.0.0.1:9912
###< symfony/var-dumper ###

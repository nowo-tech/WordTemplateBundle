<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}WordTemplate demo{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f0f4f8; }
        .demo-page { background: #fff; border-radius: 0.5rem; box-shadow: 0 1px 3px rgba(0,0,0,.08); padding: 1.5rem 1.75rem 2rem; margin-bottom: 2rem; }
        .demo-fieldset { background: #f8fafc; border-color: #cbd5e0 !important; }
        .demo-fieldset > legend { font-weight: 600; color: #2d3748; }
        .demo-table { border-collapse: collapse; width: 100%; }
        .demo-table th { background-color: #2c5282; color: #fff; border: 1px solid #2c5282; padding: 0.5rem 0.75rem; font-size: 0.875rem; }
        .demo-table td { border: 1px solid #cbd5e0; padding: 0.35rem 0.5rem; vertical-align: middle; background-color: #fff; }
        .demo-table tbody tr:nth-child(even) td { background-color: #f7fafc; }
        .demo-table .form-label { font-size: 0.75rem; margin-bottom: 0.15rem; color: #4a5568; }
        .demo-table .form-control { font-size: 0.875rem; }
        textarea.font-monospace { background-color: #1a202c; color: #e2e8f0; border-color: #4a5568; }
        textarea.font-monospace:focus { background-color: #1a202c; color: #fff; border-color: #63b3ed; box-shadow: 0 0 0 0.2rem rgba(99,179,237,.25); }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
        <div class="container">
            <a class="navbar-brand" href="{{ path('demo_home') }}">WordTemplateBundle</a>
            <span class="navbar-text text-white-50 small">Symfony 7 demo</span>
        </div>
    </nav>
    <div class="container demo-page">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
        {% endfor %}
        {% block body %}{% endblock %}
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

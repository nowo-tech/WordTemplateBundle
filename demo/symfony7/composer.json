{
    "name": "nowo-tech/word-template-demo-symfony7",
    "description": "Demo for WordTemplateBundle — Symfony 7 + FrankenPHP",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "nowo-tech/word-template-bundle": "@dev",
        "symfony/asset": "7.0.*",
        "symfony/console": "^7.0",
        "symfony/dotenv": "^7.0",
        "symfony/flex": "^2.0",
        "symfony/form": "^7.0",
        "symfony/framework-bundle": "^7.0",
        "symfony/runtime": "^7.0",
        "symfony/security-csrf": "^7.0",
        "symfony/translation": "^7.0",
        "symfony/twig-bundle": "^7.0",
        "symfony/validator": "^7.0",
        "symfony/yaml": "^7.0"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": ["@auto-scripts"],
        "post-update-cmd": ["@auto-scripts"]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.0.*"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "/var/word-template-bundle"
        }
    ],
    "require-dev": {
        "nowo-tech/twig-inspector-bundle": "*",
        "symfony/debug-bundle": "^7.0",
        "symfony/var-dumper": "^7.0",
        "symfony/web-profiler-bundle": "^7.0"
    }
}
